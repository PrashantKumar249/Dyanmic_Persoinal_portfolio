CREATE DATABASE personal_portfolio;
USE personal_portfolio;

CREATE TABLE admin (//complete
    id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(50) UNIQUE,
    password VARCHAR(255),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE profile (//complete
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100),
    title VARCHAR(150),
    about TEXT,
    profile_photo VARCHAR(255),
    resume_pdf VARCHAR(255)
);

CREATE TABLE education (//complete
    id INT AUTO_INCREMENT PRIMARY KEY,
    level VARCHAR(50),       -- 10th, 12th, B.Tech
    institute VARCHAR(150),
    board_university VARCHAR(100),
    start_year YEAR,
    end_year YEAR,
    description TEXT
);

CREATE TABLE skills (
    id INT AUTO_INCREMENT PRIMARY KEY,//complete
    skill_name VARCHAR(100),
    skill_type ENUM('Technical', 'Soft'),
    skill_level INT          -- percentage (0–100)
);

CREATE TABLE projects (     //complete// image upload pending
    id INT AUTO_INCREMENT PRIMARY KEY,
    project_name VARCHAR(150),
    description TEXT,
    technologies VARCHAR(255),
    project_image VARCHAR(255),
    github_link VARCHAR(255),
    live_link VARCHAR(255),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE experience (//complete
    id INT AUTO_INCREMENT PRIMARY KEY,
    company_name VARCHAR(150),
    role VARCHAR(100),
    start_date DATE,
    end_date DATE NULL,
    description TEXT,
    is_current BOOLEAN DEFAULT 0
);

CREATE TABLE favorites (
    id INT AUTO_INCREMENT PRIMARY KEY,
    category VARCHAR(50),   -- food, movie, music
);

CREATE TABLE travels (
    id INT AUTO_INCREMENT PRIMARY KEY,
    place_name VARCHAR(150),
    year YEAR,
    description TEXT,
    travel_image VARCHAR(255)
);

CREATE TABLE contact_messages (
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100),
    email VARCHAR(100),
    message TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
